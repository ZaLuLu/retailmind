# APP
ENVIRONMENT=development

# SECURITY
JWT_SECRET=replace_me_with_generated_secret
JWT_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# DATABASE (Neon.tech)
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.neon.tech/documind

# REDIS (Upstash — rate limiting only)
REDIS_URL=rediss://xxx.upstash.io:6379

# GEMINI (Google AI Studio)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TIMEOUT_SECONDS=30

# UPLOADS
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,webp
UPLOAD_DIR=./storage/uploads

# CORS
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# MONITORING
SENTRY_DSN=
