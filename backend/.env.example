# ============================================================
# RetailMind — Environment Variable Reference
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ── Application ───────────────────────────────────────────
ENVIRONMENT=development   # development | production

# ── Security ──────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# REQUIRED in production — no default.
JWT_SECRET=replace_with_64_char_hex_secret

JWT_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Database ──────────────────────────────────────────────
# REQUIRED — no default.
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.neon.tech/dbname?sslmode=require

# ── Redis (optional) ──────────────────────────────────────
# Used for caching. Falls back to in-memory if not set.
REDIS_URL=rediss://xxx.upstash.io:6379

# ── Google Gemini AI ──────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=30

# ── File Uploads ──────────────────────────────────────────
MAX_FILE_SIZE_MB=10
MAX_UPLOAD_ROWS=50000
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,webp,csv,xlsx,xls
UPLOAD_DIR=./storage/uploads

# ── CORS ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
# Comma-separated list of allowed origins. Use * only for local dev.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Monitoring ────────────────────────────────────────────
SENTRY_DSN=

# ── Demo Mode ─────────────────────────────────────────────
# Set DEMO_MODE=true to bypass auth for public demo deployments.
# NEVER enable in production with real user data.
DEMO_MODE=false
DEMO_USER_ID=00000000-0000-0000-0000-000000000001
DEMO_STORE_ID=00000000-0000-0000-0000-000000000002

# ── Input Limits ──────────────────────────────────────────
ADVISOR_QUESTION_MAX_LEN=1000
BULK_SALES_MAX_RECORDS=500
